page {
  --bg: #0A140A; --p: #0F1D0F; --p2: #162716; --b: #1D331D; --b2: #253D25;
  --t: #E8EFE8; --t2: #8A9E8A; --t3: #5A6E5A;
  --ac: #B8D430; --ac2: #9AB820;
  background: var(--bg); color: var(--t);
  font-family: -apple-system, "PingFang SC", sans-serif;
  font-size: 26rpx; font-weight: 400;
  line-height: 1.3;
  padding-bottom: 120rpx;
}
