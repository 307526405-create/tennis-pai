page{--g1:#1B5E3B;--g2:#2E8B57;--g3:#3DAF6E;--bg:#F4F8F2;--card:#FFF;--b:#D4DFCF;--t:#1A2E1A;--t2:#6B7F6B;--t3:#9AAE9A;background:var(--bg);color:var(--t);font-family:-apple-system,"PingFang SC",sans-serif;font-size:28rpx;font-weight:400;line-height:1.4}
.nav{display:flex;align-items:center;height:44px;padding:0 40rpx;justify-content:space-between}
.nav-search{font-size:36rpx}
.brand-wrap{display:flex;flex-direction:column;gap:4rpx}
.brand-row{display:flex;align-items:baseline}
.brand{font-size:36rpx;font-weight:600;color:var(--g1)}
.pai-wrap{position:relative}
.brand-ac{font-size:36rpx;font-weight:600;color:var(--g3)}
.pai-line{position:absolute;bottom:-2rpx;left:0;right:0;height:4rpx;background:var(--g3)}
.brand-en{font-size:20rpx;font-weight:400;color:var(--t3);letter-spacing:2rpx}
