.tabbar{position:fixed;bottom:0;left:0;right:0;display:flex;border-top:1rpx solid #D4DFCF;background:#FFF;padding:10rpx 0 40rpx;z-index:99}
.tb{flex:1;text-align:center;font-size:20rpx;color:#9AAE9A;font-weight:400}
.tb.on{color:#1B5E3B;font-weight:600}
.tb-ic{display:block;font-size:32rpx;margin-bottom:2rpx;line-height:1}
