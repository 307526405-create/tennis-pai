.tab-bar{position:fixed;bottom:0;left:0;right:0;display:flex;height:100rpx;background:#fff;border-top:1rpx solid #E0E0E0;padding-bottom:env(safe-area-inset-bottom);z-index:9999}
.tab{flex:1;display:flex;align-items:center;justify-content:center;font-size:28rpx;color:#999;font-weight:400}
.tab.on{color:#1B5E3B;font-weight:600}
