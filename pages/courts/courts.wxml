<view class="nav" style="padding-top:{{s}}px">
  <view class="brand-wrap">
    <view class="brand-row"><text class="brand">网球</text><view class="pai-wrap"><text class="brand-ac">派</text><view class="pai-line"></view></view></view>
    <text class="brand-en">TENNIS PAI</text>
  </view>
  <text class="nav-city" bindtap="pickCity">{{city}}</text>
  <text class="nav-search" bindtap="toSearch"><view class="search-icon"><view class="si-circle"></view><view class="si-line"></view></view></text>
</view>

<map latitude="{{centerLat}}" longitude="{{centerLng}}" scale="14" markers="{{markers}}" show-location style="width:100%;height:400rpx;position:fixed;top:{{44+s}}px;left:0;z-index:1"></map>

<scroll-view scroll-y style="padding-bottom:160rpx;margin-top:400rpx">
  <scroll-view scroll-x class="city-tabs">
    <view class="ctab {{curCity==='全部'?'ctab-on':''}}" bindtap="setCity" data-city="全部">全部</view>
    <view class="ctab {{curCity===c?'ctab-on':''}}" wx:for="{{cityList}}" wx:key="*this" bindtap="setCity" data-city="{{c}}">{{c}}</view>
  </scroll-view>
  <view class="clist">
    <view class="citem {{item.id===activeId?'citem-on':''}}" wx:for="{{courts}}" wx:key="id" bindtap="onTap" data-item="{{item}}">
      <view class="cno">{{index+1}}</view>
      <view class="cinfo">
        <view class="cn">{{item.name}}</view>
        <view class="ca">{{item.address||item.city}}</view>
        </view>
        <view class="c-actions">
        <view class="ca-btn" catchtap="goNav" data-item="{{item}}" wx:if="{{item.lat}}">导航</view>
        <view class="ca-btn" catchtap="goCall" data-phone="{{item.phone}}" wx:if="{{item.phone}}">电话</view>
        </view>
      <view class="cdist" wx:if="{{item.dist}}">{{item.dist}}</view>
    </view>
  </view>
  <view class="report-btn" bindtap="showReport">+ 上报球场</view>

  <view class="report-form" wx:if="{{showForm}}">
    <view class="rf-title">上报新球场</view>
    <input class="rf-input" placeholder="球场名称" value="{{rn}}" bindinput="setRn"/>
    <input class="rf-input" placeholder="城市" value="{{rc}}" bindinput="setRc"/>
    <input class="rf-input" placeholder="场地数量" value="{{rf}}" bindinput="setRf"/>
    <view class="rf-submit" bindtap="doReport">提交审核</view>
  </view>
</scroll-view>
