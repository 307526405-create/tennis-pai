<view class="nav" style="padding-top:{{s}}px">
  <view class="brand-wrap">
    <view class="brand-row"><text class="brand">网球</text><view class="pai-wrap"><text class="brand-ac">派</text><view class="pai-line"></view></view></view>
    <text class="brand-en">TENNIS PAI</text>
  </view>
  <view class="nav-search" bindtap="toSearch"><view class="search-icon"><view class="si-circle"></view><view class="si-line"></view></view></view>
</view>

<map latitude="39.92" longitude="116.40" scale="13" markers="{{markers}}" show-location style="width:100%;height:480rpx"></map>

<view class="report-btn" bindtap="showReport">+ 上报球场</view>

<view class="clist" style="padding-bottom:160rpx">

<!-- 上报表单 -->
<view class="report-form" wx:if="{{showForm}}">
  <view class="rf-title">上报新球场</view>
  <input class="rf-input" placeholder="球场名称" value="{{rname}}" bindinput="setRname"/>
  <input class="rf-input" placeholder="城市（如广州）" value="{{rcity}}" bindinput="setRcity"/>
  <input class="rf-input" placeholder="几片场地" value="{{rfields}}" bindinput="setRfields" type="number"/>
  <view class="rf-row">
    <button class="rf-btn" bindtap="submitCourt">提交</button>
    <button class="rf-btn rf-cancel" bindtap="hideForm">取消</button>
  </view>
</view>


  <view class="citem" wx:for="{{courts}}" wx:key="id">
    <view class="cno">{{index+1}}</view>
    <view class="cinfo">
      <view class="cname">{{item.name}}</view>
      <view class="cdesc">{{item.fields}}片 · {{item.indoor}} · {{item.feature||'--'}}</view>
      <view class="caddr">{{item.address||''}}</view>
    </view>
    <view class="cdist">{{item.distance||'--'}}</view>
  </view>
</view>
