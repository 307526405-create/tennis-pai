.map-btns{position:absolute;right:16rpx;bottom:80rpx;display:flex;flex-direction:column;gap:8rpx}
.mb-btn{width:64rpx;height:64rpx;background:#FFF;border-radius:8rpx;display:flex;align-items:center;justify-content:center;font-size:32rpx;font-weight:300;color:var(--t);box-shadow:0 2rpx 8rpx rgba(0,0,0,.12)}
.mb-loc{margin-top:8rpx;font-size:28rpx}

.clist{padding:0 32rpx}
.citem{display:flex;align-items:flex-start;gap:16rpx;padding:24rpx 0;border-bottom:1rpx solid #F0F0F0}
.citem-on{background:rgba(27,94,59,.04);margin:0 -32rpx;padding-left:32rpx;padding-right:32rpx}
.cno{width:40rpx;height:40rpx;border-radius:50%;background:#F5F5F5;color:var(--t3);font-size:20rpx;font-weight:600;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.cinfo{flex:1;min-width:0}
.cn{font-size:26rpx;color:var(--t);font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.ca{font-size:22rpx;color:var(--t3);margin-top:4rpx}
.cdist{font-size:22rpx;color:var(--g2);font-weight:600;flex-shrink:0}
.c-actions{display:flex;gap:8rpx;margin-top:6rpx}
.ca-btn{font-size:20rpx;color:var(--g2);padding:4rpx 14rpx;border:1rpx solid var(--g2);border-radius:12rpx;font-weight:500}

.city-tabs{white-space:nowrap;padding:16rpx 32rpx;display:flex;gap:16rpx}
.ctab{display:inline-block;font-size:24rpx;color:var(--t3);padding:6rpx 20rpx;border-radius:16rpx;background:#F5F5F5;flex-shrink:0}
.ctab-on{background:var(--g2);color:#fff;font-weight:600}

.report-btn{text-align:center;padding:16rpx;font-size:24rpx;color:var(--g2);font-weight:600;background:#F7F9F4;margin:16rpx 0;border-radius:8rpx}
.report-form{padding:24rpx;background:#FFF;border-radius:12rpx;margin-bottom:16rpx}
.rf-title{font-size:28rpx;font-weight:600;color:var(--t);margin-bottom:16rpx}
.rf-input{width:100%;padding:20rpx 0;font-size:26rpx;border-bottom:1rpx solid #F0F0F0;margin-bottom:8rpx}
.rf-submit{text-align:center;padding:20rpx;background:var(--g2);color:#fff;border-radius:8rpx;font-size:26rpx;font-weight:600;margin-top:16rpx}
