.back{font-size:36rpx;color:var(--t)}.ntitle{font-size:28rpx;font-weight:600;color:var(--t);flex:1;text-align:center}
.form{padding:20rpx 32rpx}
.tpl-bar{display:flex;align-items:center;gap:12rpx;margin-bottom:20rpx;flex-wrap:wrap}
.tpl-label{font-size:24rpx;color:var(--t3);flex-shrink:0;margin-right:4rpx}
.tpl-btn{font-size:24rpx;color:var(--t2);padding:10rpx 22rpx;border:1rpx solid #D4DFCF;border-radius:20rpx;font-weight:500;background:#FFF}
.tpl-btn.tpl-on{color:#fff;background:var(--g2);border-color:var(--g2);font-weight:600}
.group{background:#FFF;border-radius:16rpx;overflow:hidden;margin-bottom:24rpx}
.gr{display:flex;align-items:center;padding:24rpx;border-bottom:1rpx solid #F5F5F5;position:relative}
.gr:last-child{border-bottom:none}
.gl{font-size:28rpx;color:var(--t);width:96rpx;flex-shrink:0}
.gv{flex:1;font-size:28rpx;color:var(--t);text-align:right}
.gv-t{flex:1;font-size:28rpx;color:var(--t3);text-align:right}
.arr{font-size:32rpx;color:#CCC;margin-left:8rpx}
.quick-courts{display:flex;flex-wrap:wrap;gap:12rpx;padding:16rpx 24rpx}
.qc-tag{font-size:24rpx;color:var(--g2);padding:8rpx 20rpx;border:1rpx solid var(--g2);border-radius:20rpx;font-weight:500}
.qc-tag.qc-other{color:var(--t3);border-color:#E0E0E0}
.gr-in{width:100%;padding:24rpx;font-size:28rpx;color:var(--t);border-bottom:1rpx solid #F5F5F5}
.gr-in:last-child{border-bottom:none}
.submit{text-align:center;padding:28rpx;background:var(--g1);color:#fff;border-radius:14rpx;font-size:28rpx;font-weight:600;margin-top:8rpx}
