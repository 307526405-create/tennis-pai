<view class="nav" style="padding-top:{{s}}px">
  <text class="back" bindtap="back">‹</text>
  <text class="ntitle">发起约球</text>
</view>

<view class="form">
  <!-- 基本信息 -->
  <view class="group">
    <view class="gr"><text class="gl">标题</text><input class="gv" placeholder="周六3.5级单打切磋" value="{{title}}" bindinput="setT"/></view>
    <picker mode="date" value="{{dateVal}}" bindchange="onDate">
      <view class="gr"><text class="gl">日期</text><text class="gv-t">{{date||'选择日期'}}</text><text class="arr">›</text></view>
    </picker>
    <picker mode="selector" range="{{times}}" bindchange="onTime">
      <view class="gr"><text class="gl">时间</text><text class="gv-t">{{time||'选择时段'}}</text><text class="arr">›</text></view>
    </picker>
  </view>

  <!-- 场地水平 -->
  <view class="group">
    <input class="gr-in" placeholder="地点，如：朝阳公园网球中心" value="{{court}}" bindinput="setCt"/>
    <picker mode="selector" range="{{levels}}" bindchange="onLevel">
      <view class="gr"><text class="gl">水平</text><text class="gv-t">{{lv}}</text><text class="arr">›</text></view>
    </picker>
    <picker mode="selector" range="{{counts}}" bindchange="onCount">
      <view class="gr"><text class="gl">人数</text><text class="gv-t">{{tn}}人</text><text class="arr">›</text></view>
    </picker>
  </view>

  <!-- 费用备注 -->
  <view class="group">
    <view class="gr" bindtap="pickPrice">
      <text class="gl">费用</text><text class="gv-t">{{priceText||'AA制'}}</text><text class="arr">›</text>
    </view>
    <input class="gr-in" wx:if="{{price==='custom'}}" placeholder="输入金额" value="{{customPrice}}" bindinput="setCustomPrice"/>
    <input class="gr-in" placeholder="备注（选填）" value="{{note}}" bindinput="setNote"/>
  </view>

  <view class="submit" bindtap="publish">确认发起</view>
</view>
