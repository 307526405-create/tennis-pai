.pav{width:96rpx;height:96rpx;border-radius:4rpx;background:var(--g2);color:#fff;font-size:36rpx;font-weight:600;display:flex;align-items:center;justify-content:center;margin:36rpx 0 20rpx 40rpx}
.pnm{font-size:44rpx;font-weight:700;color:var(--t);padding:0 40rpx;line-height:1}
.plv{font-size:24rpx;color:var(--g2);font-weight:600;padding:8rpx 40rpx 0}
.plc{font-size:22rpx;color:var(--t3);padding:4rpx 40rpx 0}

.sts{display:flex;margin:32rpx 40rpx 0}
.sts view{flex:1;padding:8rpx 0}
.sn{font-size:40rpx;font-weight:700;color:var(--t);display:block;line-height:1}
.sl{font-size:20rpx;color:var(--t3);display:block;margin-top:2rpx}

.profile-actions{display:flex;gap:12rpx;padding:24rpx 40rpx 0}
.act-btn{flex:1;text-align:center;padding:16rpx 0;font-size:24rpx;font-weight:500;border:1rpx solid var(--t);color:var(--t);background:transparent}

.div-line{height:1rpx;background:#E8EDE0;margin:32rpx 40rpx}

.sec-h{font-size:20rpx;color:var(--t3);font-weight:600;padding:0 40rpx;margin-bottom:12rpx}
.sec-row{display:flex;padding:8rpx 40rpx;font-size:26rpx;color:var(--t)}
.sec-row .slb{color:var(--t3);width:72rpx;flex-shrink:0}

.mr{display:flex;align-items:center;gap:12rpx;padding:8rpx 40rpx;font-size:24rpx}
.mt{width:32rpx;height:32rpx;display:flex;align-items:center;justify-content:center;font-size:16rpx;font-weight:700;color:#fff;flex-shrink:0}
.mw{background:var(--g2)}.ml{background:#C83C3C}
.mi{flex:1;color:var(--t2)}.mn{color:var(--t);font-weight:600}.md{font-size:20rpx;color:var(--t3)}

.rv{font-size:24rpx;color:var(--t2);line-height:1.6;padding:6rpx 40rpx}

.contact-bar{padding:40rpx;text-align:center}
.contact-btn{display:inline-block;padding:20rpx 60rpx;background:var(--t);color:#fff;font-size:28rpx;font-weight:600}
