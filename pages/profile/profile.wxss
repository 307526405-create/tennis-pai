.cover{height:300rpx;background:linear-gradient(160deg,#1B5E3B,#2E8B57,#3DAF6E)}
.pav{width:120rpx;height:120rpx;border-radius:32rpx;background:#fff;color:var(--g1);font-size:44rpx;font-weight:600;display:flex;align-items:center;justify-content:center;margin:-60rpx auto 0;box-shadow:0 8rpx 32rpx rgba(0,0,0,.08)}
.pnm{text-align:center;font-size:36rpx;font-weight:600;color:var(--t);margin-top:16rpx}
.plv{text-align:center;font-size:26rpx;color:var(--g2);font-weight:600;margin-top:4rpx}
.plc{text-align:center;font-size:24rpx;color:var(--t3);margin:4rpx 0 24rpx}
.stats{display:flex;margin:0 32rpx 16rpx;gap:8rpx}
.stats view{flex:1;background:var(--card);border-radius:20rpx;padding:28rpx;text-align:center;box-shadow:0 2rpx 8rpx rgba(0,0,0,.03)}
.sn{font-size:44rpx;font-weight:600;color:var(--g1);display:block}
.sl{font-size:20rpx;color:var(--t3);display:block;margin-top:4rpx}
.pb{margin:0 32rpx 12rpx;background:var(--card);border-radius:24rpx;padding:28rpx;box-shadow:0 2rpx 8rpx rgba(0,0,0,.03)}
.ph{font-size:20rpx;color:var(--t3);font-weight:600;letter-spacing:2rpx;margin-bottom:12rpx}
.pts{display:flex;gap:8rpx;flex-wrap:wrap}
.pt{font-size:24rpx;padding:6rpx 16rpx;background:var(--bg);color:var(--t2);border-radius:8rpx}
.pt-a{color:var(--g2)}
.mr{display:flex;align-items:center;gap:12rpx;padding:8rpx 0;font-size:24rpx}
.mb{padding:2rpx 14rpx;font-size:20rpx;font-weight:600;border-radius:4rpx}
.mw{background:rgba(46,139,87,.08);color:var(--g2)}.ml{background:rgba(200,60,60,.06);color:#C83C3C}
.mi{flex:1;color:var(--t2)}.mn{color:var(--t);font-weight:600}.md{color:var(--t3)}
.rv{font-size:24rpx;color:var(--t2);line-height:1.5;margin-bottom:6rpx}
