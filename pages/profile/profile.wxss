.pav{width:120rpx;height:120rpx;border-radius:24rpx;background:#fff;color:var(--g1);font-size:44rpx;font-weight:600;display:flex;align-items:center;justify-content:center;margin:36rpx auto 0;box-shadow:0 4rpx 24rpx rgba(0,0,0,.06)}
.pnm{text-align:center;font-size:36rpx;font-weight:600;color:var(--t);margin-top:20rpx}
.plv{text-align:center;font-size:24rpx;color:var(--g2);font-weight:600;margin-top:4rpx}
.plc{text-align:center;font-size:22rpx;color:var(--t3);margin:4rpx 0 32rpx}
.sts{display:flex;margin:0 40rpx 20rpx;gap:12rpx}
.sts view{flex:1;background:var(--card);border-radius:20rpx;padding:28rpx 16rpx;text-align:center;box-shadow:0 2rpx 12rpx rgba(0,0,0,.04)}
.sn{font-size:36rpx;font-weight:600;color:var(--g1);display:block}
.sl{font-size:22rpx;color:var(--t3);display:block;margin-top:4rpx}
.pb{margin:0 40rpx 12rpx;background:var(--card);border-radius:20rpx;padding:28rpx;box-shadow:0 2rpx 12rpx rgba(0,0,0,.04)}
.ph{font-size:22rpx;color:var(--t3);font-weight:600;margin-bottom:14rpx}
.pts{display:flex;gap:10rpx;flex-wrap:wrap}
.pt{font-size:24rpx;padding:8rpx 20rpx;background:var(--bg);color:var(--t2);border-radius:8rpx}
.pa{color:var(--g2)}
.mr{display:flex;align-items:center;gap:12rpx;padding:10rpx 0;font-size:24rpx}
.mb{padding:2rpx 14rpx;font-size:20rpx;font-weight:600;border-radius:4rpx}
.mw{background:rgba(46,139,87,.08);color:var(--g2)}.ml{background:rgba(200,60,60,.08);color:#C83C3C}
.mi{flex:1;color:var(--t2)}.mn{color:var(--t);font-weight:600}.md{font-size:20rpx;color:var(--t3)}
.rv{font-size:24rpx;color:var(--t2);line-height:1.6;margin-bottom:8rpx}
.contact-bar{padding:40rpx;text-align:center}
.contact-btn{display:inline-block;padding:20rpx 60rpx;background:var(--g2);color:#fff;border-radius:44rpx;font-size:28rpx;font-weight:600}
