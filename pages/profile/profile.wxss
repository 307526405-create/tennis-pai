.nav-right{display:flex;align-items:center;gap:24rpx}
.edit{font-size:26rpx;color:var(--g2);font-weight:600}
.pav{width:96rpx;height:96rpx;border-radius:50%;background:var(--g2);color:#fff;font-size:36rpx;font-weight:600;display:flex;align-items:center;justify-content:center;margin:40rpx auto 0}
.pnm{text-align:center;font-size:32rpx;font-weight:600;color:var(--t);margin-top:16rpx}
.plv{text-align:center;font-size:24rpx;color:var(--g2);font-weight:600;margin-top:4rpx}
.plc{text-align:center;font-size:22rpx;color:var(--t3);margin:4rpx 0 0}
.stats{display:flex;margin:32rpx 64rpx 0}
.stats view{flex:1;text-align:center}
.sn{font-size:44rpx;font-weight:600;color:var(--g1);display:block}
.sl{font-size:22rpx;color:var(--t3);display:block;margin-top:2rpx}
.line{height:1rpx;background:#F0F0F0;margin:24rpx 64rpx}
.sec{display:flex;gap:16rpx;padding:0 64rpx;margin-bottom:16rpx}
.slab{font-size:24rpx;color:var(--t3);width:80rpx}
.sval{font-size:24rpx;color:var(--t)}
.match{display:flex;align-items:center;gap:12rpx;padding:8rpx 64rpx}
.mt{width:36rpx;height:36rpx;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:18rpx;font-weight:700;color:#fff;flex-shrink:0}
.mt.win{background:var(--g2)}.mt.lose{background:#C83C3C}
.mi{flex:1;font-size:24rpx;color:var(--t)}
.md{font-size:22rpx;color:var(--t3)}
.rv{font-size:24rpx;color:var(--t2);padding:6rpx 64rpx;line-height:1.5}
.contact-bar{padding:40rpx;text-align:center}
.contact-btn{display:inline-block;padding:20rpx 60rpx;background:var(--g2);color:#fff;border-radius:44rpx;font-size:28rpx;font-weight:600}
