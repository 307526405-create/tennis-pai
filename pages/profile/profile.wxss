.top{display:flex;align-items:flex-start;gap:24rpx;padding:32rpx}
.av{width:144rpx;height:144rpx;border-radius:50%;background:var(--g1);color:#fff;font-size:56rpx;font-weight:600;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:4rpx}
.info{flex:1;display:flex;flex-direction:column}
.name{font-size:36rpx;font-weight:600;color:var(--t)}
.lv{font-size:24rpx;color:var(--t3);margin-top:4rpx}
.nums{display:flex;gap:12rpx;margin-top:20rpx;width:100%;box-sizing:border-box}
.nc{flex:1;background:#F7F9F4;border:2rpx solid #E8EDE0;border-radius:16rpx;padding:24rpx 12rpx;text-align:center}
.nc-n{font-size:32rpx;font-weight:600;color:var(--g1);display:block}
.nc-l{font-size:20rpx;color:var(--t3);display:block;margin-top:2rpx}

.btns{display:flex;gap:12rpx;padding:0 32rpx 0}
.btn-item{flex:1;text-align:center;padding:20rpx 0;background:#F7F9F4;border-radius:16rpx;font-size:26rpx;color:var(--t);font-weight:500}
.avail-bar{padding:12rpx 32rpx 0}
.avail-toggle{text-align:center;padding:20rpx;background:#F7F9F4;border-radius:16rpx;font-size:26rpx;color:var(--t3)}
.avail-on{background:rgba(46,139,87,.08);color:var(--g2);font-weight:600}
.div{height:1rpx;background:#F0F0F0;margin:24rpx 32rpx}

.sec{padding:0 32rpx 8rpx}
.sh{font-size:22rpx;color:var(--t3);font-weight:600;letter-spacing:2rpx;margin-bottom:12rpx}
.sh-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:12rpx}
.sh-add{font-size:22rpx;color:var(--g2);font-weight:600;padding:6rpx 16rpx;background:rgba(46,139,87,.08);border-radius:8rpx}
.sr{display:flex;padding:8rpx 0;font-size:26rpx;color:var(--t)}
.srl{color:var(--t3);width:80rpx;font-size:24rpx}

.m{display:flex;align-items:center;gap:14rpx;padding:10rpx 32rpx;font-size:24rpx}
.mt{width:48rpx;height:48rpx;display:flex;align-items:center;justify-content:center;font-size:20rpx;font-weight:700;color:#fff;border-radius:4rpx;flex-shrink:0}
.mw{background:var(--g2)}.ml{background:#C83C3C}
.mi{flex:1;color:var(--t)}.ms{color:#BBB;font-weight:400}.md{font-size:22rpx;color:#CCC}

.rv{padding:12rpx 32rpx;font-size:24rpx;color:var(--t2);line-height:1.6}
.rvn{color:var(--t);font-weight:600}
.rv-star{color:#F5A623;margin:0 6rpx}
.rv-empty{padding:16rpx 32rpx;font-size:24rpx;color:var(--t3)}
.m-empty{padding:16rpx 32rpx;font-size:24rpx;color:var(--t3)}

.contact{text-align:center;padding:32rpx}
.cb{display:inline-block;padding:20rpx 40rpx;background:var(--g1);color:#fff;border-radius:12rpx;font-size:26rpx;font-weight:600;margin:8rpx}

.fav-list{display:flex;flex-wrap:wrap;gap:16rpx;padding:0 32rpx}
.fav-item{display:flex;flex-direction:column;align-items:center;gap:4rpx}
.fav-av{width:88rpx;height:88rpx;border-radius:50%;background:var(--g2);color:#fff;font-size:36rpx;font-weight:600;display:flex;align-items:center;justify-content:center}
.fav-name{font-size:24rpx;color:var(--t);font-weight:500}.fav-lv{font-size:20rpx;color:var(--t3)}

.note-banner{background:rgba(27,94,59,.08);margin:16rpx 32rpx 0;padding:20rpx 28rpx;border-radius:16rpx;border-left:6rpx solid var(--g1)}
.note-text{font-size:26rpx;color:var(--g1);font-weight:500}

.s-feedback{color:var(--t3);font-size:26rpx;padding:24rpx 32rpx;display:flex;align-items:center;justify-content:space-between}
.fb-modal{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.4);z-index:999;display:flex;align-items:center;justify-content:center}
.fb-box{background:#FFF;border-radius:16rpx;width:600rpx;padding:32rpx}
.fb-title{font-size:30rpx;font-weight:600;color:var(--t);text-align:center;margin-bottom:20rpx}
.fb-text{width:100%;height:200rpx;background:#F5F5F5;border-radius:8rpx;padding:16rpx;font-size:26rpx;margin-bottom:20rpx;box-sizing:border-box}
.fb-btns{display:flex;gap:20rpx}
.fb-cancel{flex:1;text-align:center;padding:16rpx;background:#F0F0F0;color:var(--t3);border-radius:8rpx;font-size:26rpx}
.fb-submit{flex:1;text-align:center;padding:16rpx;background:var(--g2);color:#fff;border-radius:8rpx;font-size:26rpx;font-weight:600}
