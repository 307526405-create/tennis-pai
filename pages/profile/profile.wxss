.pro-cover { height: 160rpx; background: linear-gradient(135deg, #07C160, #05A050); }
.pro-av { width: 112rpx; height: 112rpx; border-radius: 50%; background: #fff; color: #07C160; font-size: 48rpx; font-weight: 600; display: flex; align-items: center; justify-content: center; margin: -56rpx auto 0; border: 6rpx solid #fff; }
.pro-name { text-align: center; font-size: 36rpx; font-weight: 600; color: #333; margin-top: 12rpx; }
.pro-lv { text-align: center; font-size: 24rpx; color: #07C160; font-weight: 600; margin-top: 4rpx; }
.pro-loc { text-align: center; font-size: 22rpx; color: #999; margin: 4rpx 0 24rpx; }
.pro-stats { display: flex; padding: 0 48rpx 20rpx; }
.pro-stats view { flex: 1; text-align: center; }
.bn { font-size: 44rpx; font-weight: 600; color: #07C160; display: block; }
.bl { font-size: 20rpx; color: #999; display: block; margin-top: 4rpx; }

.ps-box { margin: 0 32rpx 16rpx; padding: 28rpx; border-radius: 16rpx; background: #fff; box-shadow: 0 4rpx 16rpx rgba(0,0,0,.05); }
.ps-h { font-size: 22rpx; color: #999; margin-bottom: 12rpx; font-weight: 600; }
.ps-tags { display: flex; gap: 8rpx; flex-wrap: wrap; }

.m-row { display: flex; align-items: center; gap: 12rpx; padding: 8rpx 0; font-size: 22rpx; }
.mr { font-weight: 600; padding: 2rpx 12rpx; border-radius: 4rpx; font-size: 20rpx; }
.mr.win { background: rgba(7,193,96,.1); color: #07C160; }
.mr.loss { background: rgba(255,77,79,.1); color: #FF4D4F; }
.mi { flex: 1; color: #666; }
.md { color: #999; }

.rv { font-size: 24rpx; color: #666; line-height: 1.5; margin-bottom: 8rpx; }
.rv-n { color: #333; font-weight: 600; }
