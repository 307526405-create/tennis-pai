<view class="nav" style="padding-top:{{s}}px">
  <view class="brand-wrap">
    <view class="brand-row"><text class="brand">网球</text><view class="pai-wrap"><text class="brand-ac">派</text><view class="pai-line"></view></view></view>
    <text class="brand-en">TENNIS PAI</text>
  </view>
  <text class="nav-search" bindtap="toSearch"><view class="search-icon"><view class="si-circle"></view><view class="si-line"></view></view></text>
</view>

<scroll-view scroll-y style="padding-bottom:160rpx">
  <view class="note-banner" wx:if="{{newNote}}">
    <text class="note-text">{{newNote}}</text>
  </view>
  <view class="top">
    <view class="av">{{p.name?p.name[0]:'张'}}</view>
    <view class="info">
      <view class="name">{{p.name||'张砚清'}}</view>
      <view class="lv">NTRP {{p.lv||'3.5'}} · Elo 1512 · {{p.city||'北京'}}</view>
      <view class="nums">
        <view class="nc"><text class="nc-n">32</text><text class="nc-l">场次</text></view>
        <view class="nc"><text class="nc-n">58%</text><text class="nc-l">胜率</text></view>
        <view class="nc"><text class="nc-n">4.7</text><text class="nc-l">评分</text></view>
      </view>
    </view>
  </view>

  <view class="btns"><text class="btn-item" bindtap="toEdit">编辑资料</text><text class="btn-item" bindtap="toShare">分享名片</text></view>
  <view class="avail-bar" wx:if="{{isSelf}}">
    <view class="avail-toggle {{avail?'avail-on':''}}" bindtap="toggleAvail">
      {{avail?'有空，等球友约':'想打球，通知球友'}}
    </view>
  </view>
  <view class="div"></view>

  <view class="sec">
    <view class="sh">风格·装备</view>
    <view class="sr"><text class="srl">风格</text>{{p.st||'底线进攻型'}}</view>
    <view class="sr"><text class="srl">球拍</text>{{p.g||'Blade 98 v9'}}</view>
    <view class="sr"><text class="srl">主场</text>{{p.court||'朝阳公园'}} · {{p.city||'北京'}}</view>
  </view>
  <view class="div"></view>

  <view class="sec"><view class="sh">近期战绩</view></view>
  <view class="m"><view class="mt mw">W</view><view class="mi">vs 纪云舟 <text class="ms">6-4 6-3 · 朝阳公园</text></view><view class="md">6.15</view></view>
  <view class="m"><view class="mt mw">W</view><view class="mi">vs 沈青禾 <text class="ms">7-5 4-6 10-8 · 国网中心</text></view><view class="md">6.08</view></view>
  <view class="m"><view class="mt ml">L</view><view class="mi">vs 许墨白 <text class="ms">3-6 4-6 · 国网中心</text></view><view class="md">6.01</view></view>
  <view class="div"></view>

  <view class="sec"><view class="sh">球友评价</view></view>
  <view class="rv"><text class="rvn">纪云舟</text> 反手很稳，守时靠谱，每次约球都很愉快</view>
  <view class="rv"><text class="rvn">沈青禾</text> 正手太猛了，学到了很多</view>

  <view class="contact" wx:if="{{!isSelf}}">
    <button class="cb" bindtap="toggleFav">{{favorited?'★ 常约球友':'☆ 加为常约'}}</button>
    <button class="cb" bindtap="contact">联系TA</button>
  </view>

  <view class="sec" wx:if="{{isSelf && favorites.length>0}}">
    <view class="sh">常约球友</view>
    <view class="fav-list">
      <view class="fav-item" wx:for="{{favorites}}" wx:key="id" bindtap="toP" data-id="{{item.id}}">
        <view class="fav-av">{{item.name[0]}}</view>
        <text class="fav-name">{{item.name}}</text>
        <text class="fav-lv">{{item.level}}</text>
      </view>
    </view>
  </view>
  <view class="div"></view>
  <view class="sec s-feedback" bindtap="showFeedback">意见反馈<text class="arr-s">›</text></view>

  <!-- 反馈弹框 -->
  <view class="fb-modal" wx:if="{{showFb}}" catchtap="hideFeedback">
    <view class="fb-box" catchtap>
      <view class="fb-title">建议或反馈</view>
      <textarea class="fb-text" placeholder="说说你的想法..." value="{{fbText}}" bindinput="doFbText" maxlength="500"></textarea>
      <view class="fb-btns">
        <view class="fb-cancel" bindtap="hideFeedback">取消</view>
        <view class="fb-submit" bindtap="submitFeedback">提交</view>
      </view>
    </view>
  </view>
</scroll-view>
