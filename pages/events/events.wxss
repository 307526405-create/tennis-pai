.evt{background:#FFF;margin:0 32rpx 16rpx;border-radius:12rpx;padding:24rpx}
.evt-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:10rpx}
.evt-badge{font-size:20rpx;font-weight:600;padding:4rpx 12rpx;border-radius:4rpx;background:rgba(46,139,87,.08);color:var(--g2)}.evt-badge.full{background:#F0F0F0;color:var(--t3)}
.evt-dist{font-size:22rpx;color:var(--t3)}
.evt-title{font-size:30rpx;font-weight:600;color:var(--t);margin-bottom:8rpx;line-height:1.3}
.evt-meta-row{display:flex;align-items:center;gap:8rpx;font-size:22rpx;color:var(--t2);margin-bottom:6rpx;flex-wrap:wrap}
.evt-meta-div{color:#E8E8E8;font-size:18rpx}
.evt-creator{font-size:22rpx;color:var(--t3);margin-bottom:12rpx}
.evt-foot{display:flex;align-items:center;justify-content:space-between;padding-top:12rpx;border-top:1rpx solid #F5F5F5}
.evt-participants{flex:1;min-width:0;font-size:22rpx}
.ep-name{color:var(--t);font-weight:500}.ep-more{color:var(--t3)}.ep-count{color:var(--t3)}
.join-btn{padding:12rpx 28rpx;background:var(--g2);color:#fff;border-radius:20rpx;font-size:24rpx;font-weight:600;flex-shrink:0;margin-left:12rpx}
.join-btn.join-f{background:#F0F0F0;color:var(--t3)}

.empty{text-align:center;padding:120rpx 0}
.empty-icon{font-size:64rpx;margin-bottom:16rpx}
.empty-text{font-size:26rpx;color:var(--t3);margin-bottom:24rpx}
.empty-btn{display:inline-block;padding:16rpx 40rpx;background:var(--g2);color:#fff;border-radius:20rpx;font-size:26rpx;font-weight:600}
.create-btn{font-size:22rpx;color:var(--g2);font-weight:600;padding:8rpx 16rpx;border:1rpx solid var(--g2);border-radius:20rpx}

.fab{position:fixed;right:32rpx;bottom:160rpx;width:88rpx;height:88rpx;background:var(--g2);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:48rpx;font-weight:300;box-shadow:0 4rpx 16rpx rgba(27,94,59,.3);z-index:50}
