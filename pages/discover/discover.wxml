<view class="nav" style="padding-top:{{s}}px"><text class="brand">网球<text class="brand-ac">派</text></text><text class="loc">{{loc}}</text></view>
<view class="spacer"></view>

<view class="tabs">
  <view class="tab {{a==0?'on':''}}" bindtap="sw" data-i="0">球友</view>
  <view class="tab {{a==1?'on':''}}" bindtap="sw" data-i="1">活动</view>
  <view class="tab {{a==2?'on':''}}" bindtap="sw" data-i="2">球场</view>
</view>

<view wx:if="{{a==0}}">
  <view class="list">
    <view class="card" wx:for="{{ps}}" wx:key="id" bindtap="toP">
      <view class="av" style="background:{{item.c}}">{{item.a}}</view>
      <view class="info">
        <view class="top"><text class="name">{{item.n}}</text><text class="lv">{{item.lv}}</text><text class="st">{{item.st}}</text></view>
        <text class="gear">{{item.g}} · {{item.ct}}</text>
      </view>
      <view class="sc"><text class="el">{{item.el}}</text><text class="pct">{{item.pct}}</text></view>
    </view>
  </view>
</view>

<view wx:if="{{a==1}}">
  <view class="evt" wx:for="{{es}}" wx:key="id">
    <view class="badge {{item.f?'full':''}}">{{item.f?'已满':'报名中'}}</view>
    <view class="title">{{item.t}}</view>
    <view class="meta">{{item.d}} · {{item.ct}} · {{item.lv}}</view>
    <view class="bar">
      <view class="avs"><view class="avm" wx:for="{{item.avs}}" wx:key="*this" style="background:{{item}}"></view></view>
      <text class="num">{{item.n}}/{{item.tn}}人</text>
      <view class="btn {{item.f?'btn-f':''}}">{{item.f?'已满':'报名'}}</view>
    </view>
  </view>
</view>

<view wx:if="{{a==2}}">
  <view class="map"><view class="pin" wx:for="{{cs}}" wx:key="id" style="top:{{item.y}}%;left:{{item.x}}%"></view><view class="lb" wx:for="{{cs}}" wx:key="id" style="top:{{item.y-7}}%;left:{{item.x-5}}%">{{item.name}}</view></view>
  <view class="ven">
    <view class="v" wx:for="{{cs}}" wx:key="id">
      <view class="no">{{index+1}}</view>
      <view class="vi"><view class="vn">{{item.name}}</view><view class="vs">{{item.fd}}片 · {{item.io}} · {{item.ft}}</view></view>
      <text class="vd">{{item.ds}}</text>
    </view>
  </view>
</view>

<view class="tabbar">
  <view class="tb on">发现</view>
  <view class="tb" bindtap="eq">装备库</view>
  <view class="tb" bindtap="pf">我的</view>
</view>
