.nav{padding:0 40rpx;display:flex;justify-content:space-between;align-items:center;height:88rpx}
.brand{font-size:36rpx;font-weight:600;color:var(--g1);letter-spacing:-1rpx}
.brand-ac{color:var(--g3)}
.loc{font-size:24rpx;color:var(--t2)}
.spacer{height:1rpx;background:var(--b);margin:0 40rpx;opacity:.5}

.tabs{display:flex;margin:16rpx 40rpx 0}
.tab{padding:12rpx 28rpx;font-size:28rpx;font-weight:400;color:var(--t3);border-bottom:2rpx solid transparent}
.tab.on{color:var(--g1);font-weight:600;border-bottom-color:var(--g2)}

.list{margin:20rpx 32rpx 0}
.card{background:var(--card);border-radius:24rpx;padding:28rpx;margin-bottom:16rpx;display:flex;align-items:center;gap:24rpx;box-shadow:0 2rpx 8rpx rgba(0,0,0,.03)}
.av{width:80rpx;height:80rpx;border-radius:24rpx;display:flex;align-items:center;justify-content:center;font-size:32rpx;font-weight:600;color:#fff;flex-shrink:0}
.info{flex:1;min-width:0}
.top{display:flex;align-items:center;gap:12rpx;margin-bottom:4rpx}
.name{font-size:30rpx;font-weight:600;color:var(--t)}
.lv{font-size:20rpx;background:rgba(46,139,87,.08);color:var(--g2);padding:2rpx 10rpx;border-radius:4rpx;font-weight:600}
.st{font-size:24rpx;color:var(--t2)}
.gear{font-size:22rpx;color:var(--t3);display:block}
.sc{text-align:right;flex-shrink:0}
.el{font-size:32rpx;font-weight:600;color:var(--g1);display:block}
.pct{font-size:22rpx;color:var(--t3)}

.evt{margin:20rpx 32rpx 0;background:var(--card);border-radius:24rpx;padding:28rpx;box-shadow:0 2rpx 8rpx rgba(0,0,0,.03);margin-bottom:16rpx}
.badge{font-size:20rpx;font-weight:600;padding:2rpx 16rpx;border-radius:4rpx;display:inline-block;margin-bottom:8rpx;background:rgba(46,139,87,.08);color:var(--g2)}
.badge.full{background:#F0F0F0;color:var(--t3)}
.title{font-size:30rpx;font-weight:600;color:var(--t);margin-bottom:6rpx}
.meta{font-size:24rpx;color:var(--t2);margin-bottom:16rpx}
.bar{display:flex;align-items:center;gap:10rpx}
.avs{display:flex}.avm{width:44rpx;height:44rpx;border-radius:50%;margin-left:-16rpx;border:2rpx solid #fff}.avm:first-child{margin-left:0}
.num{font-size:24rpx;color:var(--t2)}
.btn{margin-left:auto;background:var(--g2);color:#fff;padding:12rpx 32rpx;border-radius:32rpx;font-size:24rpx;font-weight:600}
.btn-f{background:#F0F0F0;color:var(--t3)}

.map{margin:20rpx 32rpx;height:400rpx;background:#EDF2E8;border-radius:20rpx;position:relative;overflow:hidden;background-image:radial-gradient(circle,#D4DFCF 1rpx,transparent 1rpx);background-size:36rpx 36rpx}
.pin{position:absolute;width:12rpx;height:12rpx;border-radius:50%;background:var(--g2);box-shadow:0 0 6rpx rgba(46,139,87,.3);transform:translate(-50%,-50%)}
.lb{position:absolute;font-size:18rpx;color:var(--t);background:#fff;padding:2rpx 6rpx;border-radius:3rpx;transform:translate(-50%,-50%)}
.ven{margin:0 32rpx}
.v{display:flex;align-items:center;gap:16rpx;background:var(--card);border-radius:20rpx;padding:24rpx;margin-bottom:12rpx;box-shadow:0 2rpx 8rpx rgba(0,0,0,.03)}
.no{width:48rpx;height:48rpx;border-radius:50%;background:var(--g2);color:#fff;font-size:24rpx;font-weight:600;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.vi{flex:1}.vn{font-size:28rpx;font-weight:600;color:var(--t)}.vs{font-size:22rpx;color:var(--t3);margin-top:2rpx}
.vd{font-size:26rpx;color:var(--g2);font-weight:600}

.tabbar{display:flex;border-top:1rpx solid var(--b);background:var(--card);padding:12rpx 0 68rpx;margin-top:auto}
.tb{flex:1;text-align:center;font-size:22rpx;color:var(--t3);font-weight:400}
.tb.on{color:var(--g1);font-weight:600}
