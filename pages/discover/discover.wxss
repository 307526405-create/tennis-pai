.loc-bar { padding: 12rpx 32rpx; font-size: 28rpx; font-weight: 600; color: #333; background: #fff; }
.filter-row { display: flex; gap: 8rpx; padding: 16rpx 32rpx; white-space: nowrap; background: #fff; }
.filter-tag { margin-right: 8rpx !important; }

/* Player list */
.player-cell { padding: 0 !important; }
.player-row { display: flex; align-items: center; gap: 16rpx; height: 88rpx; }
.p-av { width: 48rpx; height: 48rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 24rpx; font-weight: 600; color: #fff; flex-shrink: 0; }
.p-info { flex: 1; min-width: 0; }
.p-top { display: flex; align-items: center; gap: 8rpx; }
.p-name { font-size: 28rpx; font-weight: 600; color: #333; }
.p-style { font-size: 24rpx; color: #999; }
.p-gear { font-size: 20rpx; color: #999; display: block; margin-top: 4rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.p-score { text-align: right; flex-shrink: 0; }
.p-elo { font-size: 24rpx; font-weight: 600; color: #07C160; display: block; }
.p-pct { font-size: 20rpx; color: #999; }

/* Events */
.evt-list { padding: 16rpx 32rpx; }
.evt-card { background: #fff; border-radius: 16rpx; padding: 32rpx; margin-bottom: 24rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,.05); }
.evt-badge { margin-bottom: 8rpx !important; }
.evt-title { font-size: 28rpx; font-weight: 600; color: #333; margin-bottom: 8rpx; }
.evt-meta { font-size: 24rpx; color: #999; margin-bottom: 16rpx; }
.evt-bar { display: flex; align-items: center; gap: 12rpx; }
.evt-avs { display: flex; }
.evt-av { width: 48rpx; height: 48rpx; border-radius: 50%; border: 2px solid #fff; margin-left: -16rpx; }
.evt-av:first-child { margin-left: 0; }
.evt-num { font-size: 24rpx; color: #999; }
.join-btn { margin-left: auto !important; }

/* Map */
.map-box { margin: 16rpx 32rpx; height: 400rpx; border-radius: 16rpx; background: #F0F0F0; position: relative; overflow: hidden; }
.map-pin { position: absolute; width: 16rpx; height: 16rpx; border-radius: 50%; background: #07C160; box-shadow: 0 0 8rpx rgba(7,193,96,.3); transform: translate(-50%, -50%); }
.map-label { position: absolute; font-size: 20rpx; color: #333; background: #fff; padding: 2rpx 8rpx; border-radius: 4rpx; white-space: nowrap; transform: translate(-50%, -50%); }

/* Court list */
.court-cell { padding: 0 !important; }
.court-row { display: flex; align-items: center; gap: 12rpx; height: 88rpx; }
.vn-num { width: 32rpx; height: 32rpx; border-radius: 50%; background: #07C160; color: #fff; font-size: 24rpx; font-weight: 600; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.vn-info { flex: 1; }
.vn-name { font-size: 28rpx; font-weight: 600; color: #333; }
.vn-meta { font-size: 24rpx; color: #999; margin-top: 4rpx; }
.vn-dist { font-size: 24rpx; color: #07C160; font-weight: 600; flex-shrink: 0; }
