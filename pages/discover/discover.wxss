.nav{display:flex;align-items:center;height:44px;padding:0 40rpx}
.brand-wrap{display:flex;flex-direction:column;gap:4rpx}
.brand-row{display:flex;align-items:baseline}
.brand{font-size:36rpx;font-weight:600;color:var(--g1)}
.pai-wrap{position:relative}
.brand-ac{font-size:36rpx;font-weight:600;color:var(--g3)}
.pai-line{position:absolute;bottom:-2rpx;left:0;right:0;height:4rpx;background:var(--g3)}
.brand-en{font-size:20rpx;font-weight:400;color:var(--t3);letter-spacing:2rpx}

.tabs{display:flex;margin:16rpx 40rpx;gap:0}
.tab{font-size:28rpx;font-weight:400;color:var(--t3);margin-right:48rpx}
.tab.on{color:var(--t);font-weight:600}

.feed{margin:0 40rpx}
.item{display:flex;align-items:center;gap:20rpx;padding:24rpx 0;border-bottom:1rpx solid #F0F0F0}
.i-av{width:88rpx;height:88rpx;border-radius:12rpx;display:flex;align-items:center;justify-content:center;font-size:32rpx;font-weight:600;color:#fff;flex-shrink:0;position:relative}
.i-dot{position:absolute;bottom:-2rpx;right:-2rpx;width:16rpx;height:16rpx;border-radius:50%;border:2rpx solid #F5F7F3}
.dot-on{background:#3DAF6E}
.dot-off{background:#CCC}
.i-body{flex:1;min-width:0}
.i-row{display:flex;align-items:baseline;gap:12rpx;margin-bottom:6rpx}
.i-name{font-size:28rpx;font-weight:600;color:var(--t)}
.i-lv{font-size:24rpx;color:var(--g2);font-weight:600}
.i-el{font-size:22rpx;color:var(--g1);font-weight:600;margin-left:auto}
.i-row2{display:flex;gap:16rpx}
.i-gear{font-size:20rpx;color:var(--t3)}
.i-dist{font-size:20rpx;color:var(--t3)}

.evt{padding:24rpx 0;border-bottom:1rpx solid #F0F0F0}
.evt-top{display:flex;align-items:center;gap:12rpx;margin-bottom:8rpx}
.evt-date{font-size:22rpx;color:var(--t3)}
.badge{font-size:18rpx;font-weight:600;padding:2rpx 10rpx;border-radius:3rpx;background:rgba(46,139,87,.08);color:var(--g2)}
.badge.full{background:#F0F0F0;color:var(--t3)}
.evt-title{font-size:28rpx;font-weight:600;color:var(--t);margin-bottom:6rpx}
.evt-info{font-size:22rpx;color:var(--t2);margin-bottom:14rpx}
.evt-bar{display:flex;align-items:center;gap:8rpx}
.evt-avs{display:flex}.ea{width:36rpx;height:36rpx;border-radius:50%;margin-left:-10rpx;border:2rpx solid #fff}.ea:first-child{margin-left:0}
.evt-num{font-size:22rpx;color:var(--t2)}
.join{padding:8rpx 24rpx;background:var(--g2);color:#fff;border-radius:20rpx;font-size:22rpx;font-weight:600;margin-left:auto}
.join-f{background:#F0F0F0;color:var(--t3)}

.map-box{margin-bottom:16rpx;height:320rpx;background:#EDF2E8;border-radius:12rpx;position:relative;overflow:hidden}
.mp{position:absolute;display:flex;flex-direction:column;align-items:center;gap:4rpx}
.mdot{width:10rpx;height:10rpx;border-radius:50%;background:var(--g2)}
.mlb{font-size:18rpx;color:var(--t);background:#fff;padding:2rpx 6rpx;border-radius:3rpx}

.vno{width:44rpx;height:44rpx;border-radius:14rpx;background:var(--g2);color:#fff;font-size:22rpx;font-weight:600;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.vd{font-size:22rpx;color:var(--g2);font-weight:600;flex-shrink:0}

.tabbar{position:fixed;bottom:0;left:0;right:0;display:flex;border-top:1rpx solid #E0E0E0;background:rgba(255,255,255,.95);height:88rpx;padding-bottom:env(safe-area-inset-bottom);z-index:99}
.tb{flex:1;display:flex;align-items:center;justify-content:center;font-size:28rpx;color:#999;font-weight:400}
.tb.on{color:#1B5E3B;font-weight:600}
