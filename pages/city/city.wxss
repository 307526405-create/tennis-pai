.back{font-size:36rpx;color:var(--t)}.ntitle{font-size:28rpx;font-weight:600;color:var(--t);flex:1;text-align:center}
body{padding:80rpx 32rpx}

.loc{padding:24rpx 32rpx;background:#FFF;margin-bottom:16rpx}
.loc-label{font-size:22rpx;color:var(--t3);margin-bottom:8rpx}
.loc-row{display:flex;align-items:center;justify-content:space-between;font-size:30rpx;color:var(--t);font-weight:600}
.loc-done{color:var(--g2);font-weight:700}

.block{padding:16rpx 32rpx}
.bl{font-size:22rpx;color:var(--t3);font-weight:600;margin-bottom:12rpx;letter-spacing:2rpx}

.hot-grid{display:flex;flex-wrap:wrap;gap:20rpx}
.h-item{font-size:26rpx;color:var(--t);padding:12rpx 32rpx;background:#F5F5F5;border-radius:8rpx}
.h-on{background:rgba(27,94,59,.08);color:var(--g2);font-weight:600}

.search-input{width:100%;padding:20rpx;font-size:26rpx;background:#F5F5F5;border-radius:8rpx;margin-bottom:12rpx;box-sizing:border-box}
.result{font-size:26rpx;color:var(--t);padding:16rpx 0;border-bottom:1rpx solid #F0F0F0}

.all-warp{display:flex;flex-wrap:wrap;gap:16rpx}
.a-item{font-size:26rpx;color:var(--t);padding:10rpx 28rpx;background:#F5F5F5;border-radius:8rpx}
.a-on{background:rgba(27,94,59,.08);color:var(--g2);font-weight:600}
