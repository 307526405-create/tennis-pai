<view class="nav" style="padding-top:{{s}}px">
  <text class="back" bindtap="back">‹</text>
  <text class="ntitle">选择城市</text>
</view>

<scroll-view scroll-y style="padding-bottom:40rpx;margin-top:44px">
  <view class="loc" wx:if="{{autoCity}}">
    <text class="loc-label">自动定位</text>
    <view class="loc-row" bindtap="selAuto">
      <text class="loc-name">{{autoCity}}</text>
      <text class="loc-done" wx:if="{{autoCity===city}}">✓</text>
    </view>
  </view>

  <view class="block">
    <view class="bl">热门城市</view>
    <view class="hot-grid">
      <view class="h-item" wx:for="{{hots}}" wx:key="*this" bindtap="selCity" data-city="{{item}}">{{item}}</view>
    </view>
  </view>

  <view class="block">
    <view class="bl">搜索城市</view>
    <input class="search-input" placeholder="输入城市名" value="{{kw}}" bindinput="onKw"/>
    <view class="result" wx:for="{{results}}" wx:key="*this" bindtap="selCity" data-city="{{item}}">{{item}}</view>
  </view>

  <view class="block">
    <view class="bl">全部城市</view>
    <view class="all-warp">
      <view class="a-item" wx:for="{{allCities}}" wx:key="*this" bindtap="selCity" data-city="{{item}}">{{item}}</view>
    </view>
  </view>
</scroll-view>
