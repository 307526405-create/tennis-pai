<view class="nav" style="padding-top:{{s}}px">
  <view class="brand-wrap">
    <view class="brand-row"><text class="brand">网球</text><view class="pai-wrap"><text class="brand-ac">派</text><view class="pai-line"></view></view></view>
    <text class="brand-en">TENNIS PAI</text>
  </view>
</view>

<view class="eq-tabs">
  <view class="eqt on">球拍</view><view class="eqt">球鞋</view><view class="eqt">服装</view><view class="eqt">球线</view>
</view>

<view class="filter">
  <view class="fg {{showBrand?'fg-open':''}}" bindtap="toggleBrand">品牌<text class="fg-arrow">▼</text></view>
  <view class="fg {{showType?'fg-open':''}}" bindtap="toggleType">类型<text class="fg-arrow">▼</text></view>
</view>

<view class="fo" wx:if="{{showBrand}}">
  <view class="fi {{bi==i?'on':''}}" wx:for="{{brands}}" wx:key="*this" bindtap="selBrand" data-i="{{index}}">{{item}}</view>
</view>
<view class="fo" wx:if="{{showType}}">
  <view class="fi {{ti==i?'on':''}}" wx:for="{{types}}" wx:key="*this" bindtap="selType" data-i="{{index}}">{{item}}</view>
</view>

<scroll-view scroll-y class="grid">
  <view class="card" wx:for="{{rs}}" wx:key="id" bindtap="toD" data-id="{{index}}">
    <view class="card-img">🎾</view>
    <view class="card-body">
      <view class="card-name">{{item.model}}</view>
      <view class="card-price">¥{{item.price}}</view>
    </view>
  </view>
</scroll-view>
