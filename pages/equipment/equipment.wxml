<view class="nav" style="padding-top:{{s}}px">
  <view class="brand-wrap">
    <view class="brand-row">
      <text class="brand">装备<text class="brand-ac">库</text></text>
    </view>
    <text class="brand-en">EQUIPMENT</text>
  </view>
</view>

<view class="eq-tabs">
  <view class="eqt on">球拍</view>
  <view class="eqt">球鞋</view>
  <view class="eqt">球线</view>
  <view class="eqt">服装</view>
</view>

<scroll-view scroll-x class="brand-bar">
  <view class="bg" bindtap="sb">
    <text class="bg-t">品牌</text>
    <text class="bg-v">{{brands[bb]}}</text>
    <text class="bg-arrow">▼</text>
  </view>
</scroll-view>

<view class="elist">
  <view class="erow" wx:for="{{rs}}" wx:key="id" bindtap="toD" data-id="{{index}}">
    <view class="ethumb">🎾</view>
    <view class="einfo">
      <view class="etop">
        <text class="ebrand">{{item.brand}}</text>
        <text class="etype">{{item.type}}</text>
      </view>
      <view class="ename">{{item.model}}</view>
      <view class="espec">{{item.head}}in² · {{item.weight}} · {{item.balance}} · RA{{item.ra}}</view>
    </view>
    <view class="eright">
      <text class="eprice">¥{{item.price}}</text>
    </view>
  </view>
</view>

<view class="tabbar">
  <view class="tb" bindtap="goD">发现</view>
  <view class="tb on">装备库</view>
  <view class="tb" bindtap="goP">我的</view>
</view>
