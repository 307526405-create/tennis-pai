.brand-bar{display:flex;gap:12rpx;padding:20rpx 40rpx;white-space:nowrap}
.bb{padding:8rpx 20rpx;font-size:24rpx;color:var(--t2);background:#FFF;border-radius:20rpx;font-weight:400}
.bb-on{background:var(--t);color:#fff;font-weight:600}

.grid{display:flex;flex-wrap:wrap;padding:0 40rpx;gap:16rpx}
.card{width:calc(50% - 8rpx);background:#FFF;border-radius:12rpx;overflow:hidden}
.card-img{width:100%;height:280rpx;background:#F4F8F2;display:flex;align-items:center;justify-content:center;font-size:64rpx}
.card-body{padding:20rpx}
.card-brand{font-size:20rpx;color:var(--t3);font-weight:600;margin-bottom:4rpx}
.card-name{font-size:26rpx;font-weight:600;color:var(--t);line-height:1.3;margin-bottom:8rpx}
.card-price{font-size:28rpx;font-weight:700;color:#C83C3C}
