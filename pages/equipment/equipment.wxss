.eq-list { background: #fff; }
.eq-row { padding: 0 !important; }
.eq-item { display: flex; align-items: center; gap: 16rpx; height: 96rpx; }
.eq-thumb { width: 56rpx; height: 56rpx; border-radius: 8rpx; background: #F5F5F5; display: flex; align-items: center; justify-content: center; font-size: 32rpx; flex-shrink: 0; }
.eq-info { flex: 1; min-width: 0; }
.eq-brand { font-size: 20rpx; color: #999; font-weight: 600; }
.eq-name { font-size: 28rpx; font-weight: 600; color: #333; }
.eq-spec { font-size: 24rpx; color: #999; }
.eq-price { font-size: 28rpx; font-weight: 600; color: #333; flex-shrink: 0; }
