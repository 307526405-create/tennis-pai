.eq-tabs{display:flex;margin:16rpx 40rpx;gap:0;border-bottom:1rpx solid #E8E8E8}
.eqt{padding:16rpx 0;margin-right:48rpx;font-size:28rpx;color:var(--t3);font-weight:400}
.eqt.on{color:var(--t);font-weight:600;border-bottom:2rpx solid var(--g2);margin-bottom:-1rpx}

.pick-row{display:flex;gap:16rpx;padding:16rpx 40rpx}
.pick{display:flex;align-items:center;gap:6rpx;padding:10rpx 20rpx;background:#FFF;border:1rpx solid #E8E8E8;border-radius:8rpx;font-size:22rpx}
.pick-t{color:var(--t3)}.pick-v{color:var(--t);font-weight:600}.pick-arrow{font-size:14rpx;color:var(--t3)}
.pick-menu{position:fixed;inset:0;z-index:100;display:flex;align-items:flex-start;justify-content:center}
.pick-mask{position:absolute;inset:0;background:rgba(0,0,0,.15)}
.pick-list{position:relative;margin-top:300rpx;width:500rpx;background:#FFF;border-radius:12rpx;padding:8rpx 0;box-shadow:0 8rpx 32rpx rgba(0,0,0,.12);animation:fadeIn .15s}
@keyframes fadeIn{from{opacity:0;transform:translateY(-8rpx)}to{opacity:1;transform:translateY(0)}}
.pick-opt{padding:20rpx 32rpx;font-size:26rpx;color:var(--t);text-align:center}
.pick-opt.on{color:var(--g2);font-weight:600}
.pick-opt+.pick-opt{border-top:1rpx solid #F0F0F0}

.elist{margin:0 40rpx}
.erow{display:flex;align-items:center;gap:20rpx;padding:24rpx 0;border-bottom:1rpx solid #F0F0F0}
.ethumb{width:96rpx;height:96rpx;border-radius:8rpx;background:#F4F8F2;display:flex;align-items:center;justify-content:center;font-size:40rpx;flex-shrink:0}
.einfo{flex:1;min-width:0}
.etop{display:flex;align-items:center;gap:10rpx;margin-bottom:4rpx}
.ebrand{font-size:20rpx;color:var(--t3);font-weight:600}
.etype{font-size:18rpx;color:var(--g2);background:rgba(46,139,87,.06);padding:1rpx 8rpx;border-radius:3rpx}
.ename{font-size:28rpx;font-weight:600;color:var(--t);margin-bottom:4rpx}
.espec{font-size:20rpx;color:var(--t3)}
.eright{flex-shrink:0;text-align:right}
.eprice{font-size:28rpx;font-weight:600;color:var(--g1)}
