.grid{display:flex;flex-wrap:wrap;padding:20rpx 32rpx;gap:12rpx}
.card{width:calc(50% - 6rpx);background:#FFF;border-radius:8rpx;overflow:hidden}
.card-img{width:100%;height:260rpx;background:#F4F8F2;display:flex;align-items:center;justify-content:center;font-size:56rpx}
.card-info{padding:16rpx}
.card-name{font-size:26rpx;font-weight:600;color:var(--t)}
.card-price{font-size:28rpx;font-weight:700;color:#C83C3C;margin-top:4rpx}
