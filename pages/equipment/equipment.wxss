.eq-tabs{display:flex;margin:16rpx 40rpx;gap:0;border-bottom:1rpx solid #E8E8E8}
.eqt{padding:16rpx 0;margin-right:48rpx;font-size:28rpx;color:var(--t3);font-weight:400}
.eqt.on{color:var(--t);font-weight:600;border-bottom:2rpx solid var(--g2);margin-bottom:-1rpx}

.filter{display:flex;gap:16rpx;padding:16rpx 40rpx}
.fg{display:flex;align-items:center;gap:6rpx;padding:10rpx 20rpx;background:#FFF;border:1rpx solid #E8E8E8;border-radius:8rpx;font-size:22rpx;color:var(--t3)}
.fg-arrow{font-size:14rpx;color:var(--t3)}
.fg-open{border-color:var(--t);color:var(--t)}

.fo{display:flex;flex-wrap:wrap;gap:8rpx;padding:0 40rpx 16rpx}
.fi{padding:8rpx 20rpx;font-size:22rpx;color:var(--t2);background:#FFF;border:1rpx solid #E8E8E8;border-radius:16rpx}
.fi.on{background:var(--t);color:#fff;border-color:var(--t);font-weight:600}

.grid{display:flex;flex-wrap:wrap;padding:8rpx 32rpx 16rpx;justify-content:space-between}
.card{width:330rpx;background:#FFF;border-radius:8rpx;overflow:hidden;margin-bottom:16rpx}
.card-img{width:100%;height:280rpx;background:#F4F8F2;display:flex;align-items:center;justify-content:center;font-size:56rpx}
.card-body{padding:16rpx}
.card-name{font-size:26rpx;font-weight:600;color:var(--t);line-height:1.3}
.card-price{font-size:30rpx;font-weight:700;color:#C83C3C;margin-top:6rpx}
