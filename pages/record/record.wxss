.back{font-size:36rpx;color:var(--t)}.ntitle{font-size:28rpx;font-weight:600;color:var(--t);flex:1;text-align:center}.submit{font-size:26rpx;color:var(--g2);font-weight:600}

.form{padding:0 40rpx}
.fg{padding:28rpx 0;border-bottom:1rpx solid #F0F0F0}
.fl{font-size:26rpx;color:var(--t3);margin-bottom:12rpx}
.fi{font-size:28rpx;color:var(--t);width:100%}
.picker{font-size:28rpx;color:var(--t);padding:12rpx 0}

.score-row{display:flex;align-items:center;gap:16rpx}
.si{flex:1;font-size:36rpx;color:var(--t);text-align:center;background:#F7F9F4;border-radius:12rpx;padding:20rpx 0;font-weight:600}
.score-dash{font-size:36rpx;color:var(--t3);font-weight:600}

.submit-btn-wrap{padding:40rpx 0 60rpx}
.submit-btn{text-align:center;padding:24rpx 0;background:var(--g1);color:#fff;border-radius:12rpx;font-size:30rpx;font-weight:600}
