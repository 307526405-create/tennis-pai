.d-top { height: 400rpx; background: #F5F5F5; display: flex; align-items: center; justify-content: center; font-size: 96rpx; }
.d-body { padding: 32rpx; }
.d-brand { font-size: 20rpx; color: #999; font-weight: 600; }
.d-name { font-size: 40rpx; font-weight: 600; color: #333; margin: 4rpx 0; }
.d-rate { font-size: 26rpx; color: #07C160; margin-bottom: 16rpx; }
.d-tags { display: flex; gap: 8rpx; margin-bottom: 16rpx; }
.sec-t { font-size: 24rpx; font-weight: 600; color: #333; margin: 28rpx 0 12rpx; }
.s-grid { display: flex; flex-wrap: wrap; border-radius: 16rpx; overflow: hidden; border: 1rpx solid #F0F0F0; }
.sg { width: 50%; padding: 20rpx 24rpx; box-sizing: border-box; border-bottom: 1rpx solid #F0F0F0; border-right: 1rpx solid #F0F0F0; }
.sg:nth-child(2n) { border-right: none; }
.sg:nth-last-child(-n+2) { border-bottom: none; }
.sgl { font-size: 20rpx; color: #999; display: block; margin-bottom: 4rpx; }
.sgv { font-size: 24rpx; color: #333; font-weight: 600; }
.price-row { display: flex; gap: 8rpx; }
.p-card { flex: 1; padding: 20rpx 16rpx; border-radius: 16rpx; background: #FAFAFA; text-align: center; }
.pc-s { font-size: 20rpx; color: #999; display: block; }
.pc-a { font-size: 32rpx; font-weight: 600; color: #FF4D4F; display: block; margin: 4rpx 0; }
.pc-l { font-size: 20rpx; color: #07C160; }
.comment { padding: 20rpx; background: #fff; border-radius: 12rpx; margin-bottom: 12rpx; border: 1rpx solid #F0F0F0; }
.c-user { font-size: 24rpx; font-weight: 600; color: #333; }
.c-text { font-size: 24rpx; color: #666; margin: 4rpx 0; line-height: 1.5; }
.c-meta { font-size: 20rpx; color: #999; }
