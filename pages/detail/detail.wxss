.d-top{height:500rpx;background:var(--p2);display:flex;align-items:center;justify-content:center;font-size:120rpx;border-bottom:1rpx solid var(--b)}
.d-body{padding:28rpx}
.d-name{font-size:40rpx;font-weight:900;color:var(--t);margin:4rpx 0;letter-spacing:-0.5rpx}
.d-rate{font-size:24rpx;color:var(--t2);margin-bottom:12rpx}
.d-stars{color:var(--ac)}
.d-tags{display:flex;gap:8rpx;margin-bottom:16rpx}
.d-tag{padding:4rpx 14rpx;font-size:20rpx;background:rgba(184,212,48,.08);color:var(--ac);font-weight:600}

.sec-t{font-size:24rpx;font-weight:700;color:var(--t2);margin:28rpx 0 12rpx;letter-spacing:2rpx}
.s-grid{display:flex;flex-wrap:wrap;border:1rpx solid var(--b);background:var(--b)}
.sg{width:50%;padding:20rpx 24rpx;box-sizing:border-box;background:var(--p);border-bottom:1rpx solid var(--b);border-right:1rpx solid var(--b)}
.sg:nth-child(2n){border-right:none}
.sg:nth-last-child(-n+2){border-bottom:none}
.sgl{font-size:20rpx;color:var(--t3);display:block;margin-bottom:4rpx}
.sgv{font-size:24rpx;color:var(--t);font-weight:700}

.price-row{display:flex;gap:8rpx}
.pc{flex:1;padding:20rpx 12rpx;background:var(--p);border:1rpx solid var(--b);text-align:center}
.pcs{font-size:20rpx;color:var(--t3);display:block}
.pca{font-size:30rpx;font-weight:700;color:#C44536;display:block;margin:4rpx 0}
.pcl{font-size:20rpx;color:var(--ac)}

.cmt{padding:20rpx;background:var(--p);border:1rpx solid var(--b);margin-bottom:10rpx}
.c-u{font-size:24rpx;font-weight:700;color:var(--t)}
.c-t{font-size:24rpx;color:var(--t2);margin:4rpx 0;line-height:1.5}
.c-m{font-size:20rpx;color:var(--t3)}
