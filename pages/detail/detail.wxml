<view class="nav" style="padding-top:{{statusBar}}px">
  <view class="nav-l" bindtap="back"><text class="back">‹</text><text class="ntitle">装备详情</text></view>
</view>

<scroll-view scroll-y wx:if="{{r}}">
  <view class="d-top"></view>
  <view class="db">
    <view class="etop"><text class="ebrand">{{r.brand}}</text><text class="etype">{{r.type}}</text></view>
    <view class="dname">{{r.model}}</view>
    <view class="dstar" wx:if="{{r.star}}">⭐ {{r.star}}</view>
  </view>

  <view class="db">
    <view class="dh">规格参数</view>
    <view class="sg">
      <view class="sgi"><text class="sl">拍面</text><text class="sv">{{r.head}} sq in</text></view>
      <view class="sgi"><text class="sl">空拍重量</text><text class="sv">{{r.weight}}</text></view>
      <view class="sgi"><text class="sl">平衡点</text><text class="sv">{{r.balance}}</text></view>
      <view class="sgi"><text class="sl">线床</text><text class="sv">{{r.pattern}}</text></view>
      <view class="sgi"><text class="sl">硬度</text><text class="sv">RA {{r.ra}}</text></view>
      <view class="sgi"><text class="sl">挥重</text><text class="sv">{{r.sw}}</text></view>
      <view class="sgi"><text class="sl">拍框厚度</text><text class="sv">{{r.beam}}</text></view>
      <view class="sgi"><text class="sl">长度</text><text class="sv">27 in</text></view>
    </view>
  </view>

  <view class="db">
    <view class="dh">参考价格</view>
    <view class="prices">
      <view class="pc" bindtap="goBuy" data-link="https://s.click.taobao.com/xxx">
        <text class="pcn">淘宝</text><text class="pca">¥{{r.price - 200}}</text>
        <text class="pcl">点击购买→</text>
      </view>
      <view class="pc" bindtap="goBuy" data-link="https://s.click.taobao.com/yyy">
        <text class="pcn">天猫</text><text class="pca2">¥{{r.price}}</text>
        <text class="pcl">点击购买→</text>
      </view>
      <view class="pc" bindtap="goBuy" data-link="https://s.click.jd.com/zzz">
        <text class="pcn">京东</text><text class="pca2">¥{{r.price - 81}}</text>
        <text class="pcl">点击购买→</text>
      </view>
    </view>
  </view>

  <view class="db">
  <view class="dh">球友讨论</view>
  <view class="cmt"><view class="cu"><text class="cun">老张</text><text class="cus">5分</text></view><view class="ct">用了半年，控制感极好。比v8更吃球，反手切削稳多了。</view><view class="cm">12 赞 · 2天前</view></view>
  <view class="cmt"><view class="cu"><text class="cun">小美</text><text class="cus">4分</text></view><view class="ct">颜值满分，甜区偏小新手慎重。从Clash换过来需要适应几周。</view><view class="cm">8 赞 · 5天前</view></view>
  </view>
</scroll-view>
