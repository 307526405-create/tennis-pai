<view class="page">
  <view class="card" id="card">
    <view class="c-top">
      <view class="c-av">张</view>
      <view class="c-name">{{p.name||'老张'}}</view>
      <view class="c-lv">NTRP {{p.lv||'3.5'}}</view>
    </view>
    <view class="c-stats">
      <view class="cs"><text class="csn">32</text><text class="csl">场次</text></view>
      <view class="cs"><text class="csn">58%</text><text class="csl">胜率</text></view>
      <view class="cs"><text class="csn">4.7</text><text class="csl">评分</text></view>
    </view>
    <view class="c-row">
      <text class="cl">风格</text><text class="cv">{{p.sn||'底线进攻型'}}</text>
    </view>
    <view class="c-row">
      <text class="cl">装备</text><text class="cv">{{p.g||'Wilson Blade 98 v9'}}</text>
    </view>
    <view class="c-row">
      <text class="cl">主场</text><text class="cv">{{p.court||'朝阳公园'}} · {{p.city||'北京'}}</text>
    </view>
    <view class="c-qr">扫码创建你的网球身份</view>
  </view>
  <view class="actions">
    <button class="btn" bindtap="saveImg">保存到相册</button>
    <button class="btn btn-share" open-type="share">分享给球友</button>
  </view>
</view>
<canvas type="2d" id="myCanvas" style="position:fixed;left:-9999px;width:600rpx;height:800rpx"></canvas>
