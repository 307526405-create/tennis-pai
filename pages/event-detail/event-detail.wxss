/* 导航栏 */
.nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: var(--bg);
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 44px;
  padding: 0 32rpx;
}
.nav-back {
  font-size: 28rpx;
  color: var(--g2);
  font-weight: 500;
  width: 120rpx;
}
.nav-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--t);
}
.nav-placeholder {
  width: 120rpx;
}

/* 主体 */
.body {
  padding-top: 44px;
  padding-bottom: 160rpx;
}
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100vh;
  color: var(--t3);
  font-size: 28rpx;
}

/* 英雄区 */
.hero {
  background: linear-gradient(135deg, #1B5E3B 0%, #2E8B57 100%);
  padding: 48rpx 32rpx 40rpx;
}
.hero-status {
  display: inline-block;
  font-size: 22rpx;
  font-weight: 600;
  color: #fff;
  background: rgba(255,255,255,0.2);
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  margin-bottom: 16rpx;
}
.hero-status.full {
  background: rgba(255,255,255,0.12);
  color: rgba(255,255,255,0.7);
}
.hero-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.3;
}

/* 信息卡片 */
.info-card {
  background: #fff;
  margin: -16rpx 24rpx 20rpx;
  border-radius: 16rpx;
  padding: 28rpx 28rpx 8rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
}
.info-row {
  display: flex;
  align-items: center;
  padding-bottom: 24rpx;
}
.info-icon {
  width: 40rpx;
  height: 40rpx;
  border-radius: 10rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #fff;
  font-weight: 600;
}
.i-time { background: #5B8DEF; }
.i-court { background: #F5A623; }
.i-level { background: #E85D75; }
.i-people { background: #7ED321; }
.i-price { background: #9B59B6; }

/* 图标用文字替代 */
.i-time::after { content: '时'; }
.i-court::after { content: '场'; }
.i-level::after { content: '级'; }
.i-people::after { content: '人'; }
.i-price::after { content: '费'; }

.info-content {
  flex: 1;
  min-width: 0;
}
.info-label {
  display: block;
  font-size: 22rpx;
  color: var(--t3);
  margin-bottom: 2rpx;
}
.info-value {
  display: block;
  font-size: 28rpx;
  color: var(--t);
  font-weight: 500;
}

/* 通用区块 */
.section {
  background: #fff;
  margin: 0 24rpx 16rpx;
  border-radius: 16rpx;
  padding: 28rpx;
}
.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--t2);
  margin-bottom: 20rpx;
  display: block;
}

/* 发起人 */
.creator-card {
  display: flex;
  align-items: center;
}
.creator-info {
  margin-left: 16rpx;
}
.creator-name {
  display: block;
  font-size: 28rpx;
  color: var(--t);
  font-weight: 500;
}
.creator-level {
  display: block;
  font-size: 22rpx;
  color: var(--t3);
  margin-top: 2rpx;
}

/* 头像 */
.avatar-sm {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: var(--g2);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* 玩家列表 */
.player-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.player-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}
.player-item:last-child {
  border-bottom: none;
}
.player-name {
  margin-left: 16rpx;
  font-size: 28rpx;
  color: var(--t);
  font-weight: 500;
  flex: 1;
}
.player-level {
  font-size: 24rpx;
  color: var(--g2);
  font-weight: 500;
  background: rgba(46,139,87,0.08);
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
}

.empty-players {
  text-align: center;
  padding: 32rpx 0;
}
.empty-text {
  font-size: 24rpx;
  color: var(--t3);
}

/* 底部间距 */
.bottom-spacer {
  height: 40rpx;
}

/* 底部固定栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 16rpx rgba(0,0,0,0.04);
  z-index: 50;
}
.bb-info {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}
.bb-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #E85D75;
}
.bb-count {
  font-size: 22rpx;
  color: var(--t3);
}
.bb-btn {
  padding: 18rpx 48rpx;
  background: var(--g2);
  color: #fff;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
}
.bb-btn.bb-cancel {
  background: #F5F5F5;
  color: var(--t3);
}
.bb-btn.bb-full {
  background: #F0F0F0;
  color: var(--t3);
}
